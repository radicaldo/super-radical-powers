{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "TaskStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/lesson-tracker.py inject",
            "async": false
          }
        ]
      }
    ],
    "TaskComplete": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/lesson-tracker.py parse \"{{task_context}}\"",
            "async": false
          }
        ]
      }
    ]
  }
}